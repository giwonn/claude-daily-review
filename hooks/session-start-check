#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

result=$(CLAUDE_PLUGIN_DATA="${CLAUDE_PLUGIN_DATA}" node "${PLUGIN_ROOT}/lib/check-config.mjs" 2>/dev/null || echo "NEEDS_SETUP")

msg=""
if [ "$result" = "NEEDS_SETUP" ]; then
  msg='<important-reminder>IN YOUR FIRST REPLY YOU MUST TELL THE USER: daily-review 플러그인이 아직 설정되지 않았습니다. /daily-review-setup 을 실행해주세요.</important-reminder>'
elif [ "$result" = "NEEDS_MIGRATE" ]; then
  msg='<important-reminder>IN YOUR FIRST REPLY YOU MUST TELL THE USER: daily-review 0.5.0으로 업데이트되어 raw 로그 구조가 변경되었습니다. 모든 Claude Code 세션을 종료한 뒤 /daily-review-migrate 를 실행해주세요.</important-reminder>'
elif [ "$result" = "NEEDS_INDEX" ]; then
  msg='<important-reminder>IN YOUR FIRST REPLY YOU MUST TELL THE USER: daily-review 인덱스가 없습니다. /daily-review-migrate 를 실행하여 인덱스를 생성해주세요.</important-reminder>'
fi

if [ -n "$msg" ]; then
  if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$msg"
  else
    printf '{"additional_context":"%s"}\n' "$msg"
  fi
fi

exit 0
